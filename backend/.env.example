# Runtime environment
APP_ENV=development

# Security baseline (required in production)
ACCESS_CONTROL_TOKEN_SECRET=change-me-with-32-plus-random-characters
ENABLE_API_DOCS=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UNLIMITED_ANON_QUOTA=false

# App behavior
ANONYMOUS_QUOTA_LIMIT=3
QUOTA_WINDOW_DAYS=7
ANALYSIS_TTL_SECONDS=86400
CONVERSION_JOB_ACTIVE_TTL_SECONDS=86400
CONVERSION_JOB_TERMINAL_TTL_SECONDS=86400
DATABASE_URL=
DATABASE_SCHEMA=public
PDF_OCR_ENABLED=
PDF_OCR_LANG=por+eng
PDF_OCR_MAX_PAGES=12
PDF_OCR_DPI=250
PDF_OCR_MAX_FILE_MB=5
PDF_OCR_PAGE_TIMEOUT_SECONDS=12
PDF_OCR_CONCURRENCY_LIMIT=1

# Optional Textract OCR for scanned PDFs
TEXTRACT_ENABLED=
TEXTRACT_MODE=text
TEXTRACT_FORCE=
AWS_REGION=us-east-1
TEXTRACT_TEMP_BUCKET=
TEXTRACT_S3_PREFIX=textract/tmp/
TEXTRACT_JOB_POLL_INTERVAL_SECONDS=2
TEXTRACT_JOB_TIMEOUT_SECONDS=600
TEXTRACT_FEATURE_TYPES=TABLES,LAYOUT

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_BASE_URL=http://localhost:3000
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
